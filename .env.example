# ===== 大模型 =====
GEMINI_API_KEY=AIza...
# GEMINI_API_KEYS=key1,key2,key3  # 多 key 轮询

# ===== 服务 =====
BASE_URL=http://localhost:8000

# ===== 安全体系 (Batch 1) =====
# HMAC 签名密钥。任意 32+ 位随机字符串；生产环境必须换新且妥善保管。
# 生成：python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SAFETY_SECRET=REPLACE_ME_WITH_RANDOM_48_CHAR_SECRET

# 是否启用 auth（本地开发可设 false 便于调试；生产必须 true）
SAFETY_AUTH_ENABLED=true

# 反向代理注入用户 email 的 header 名；公司上了 SSO 网关后配置此项
# 留空则仅走 Bearer Token 模式
SAFETY_TRUSTED_PROXY_HEADER=
